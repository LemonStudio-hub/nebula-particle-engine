# Nebula Particle Engine - Environment Variables Example
# Copy this file to .env.local and configure as needed

# Application
VITE_APP_TITLE=Nebula Particle Engine
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_PERFORMANCE_MONITOR=true
VITE_ENABLE_DEBUG_MODE=false

# Rendering
VITE_DEFAULT_RENDERER=webgpu
VITE_MAX_PARTICLES=100000
VITE_INITIAL_PARTICLES=10000

# Performance
VITE_TARGET_FPS=60
VITE_MIN_FPS=30
VITE_ENABLE_AUTO_FALLBACK=true

# Analytics (Optional)
# VITE_ANALYTICS_ID=your-analytics-id